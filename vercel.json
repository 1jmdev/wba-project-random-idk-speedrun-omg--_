{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "bunVersion": "1.x",
    "buildCommand": "bun run build",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api(.*)",
            "destination": "api/"
        },
        {
            "source": "/(.*)",
            "destination": "index.html"
        }
    ],
    "regions": ["iad1"]
}
