{
    "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
    "files": {
        "includes": [
            "**",
            "!dist",
            "!node_modules",
            "!coverage",
            "!bun.lock",
            "!package-lock.json",
            "!yarn.lock"
        ]
    },
    "formatter": {
        "enabled": true,
        "lineWidth": 80,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf"
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "trailingCommas": "es5",
            "semicolons": "asNeeded"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "useExhaustiveDependencies": "warn",
                "useHookAtTopLevel": "error"
            },
            "suspicious": {
                "noExplicitAny": "warn"
            }
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": {
                    "level": "on"
                }
            }
        }
    }
}
