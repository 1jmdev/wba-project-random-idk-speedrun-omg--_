generator client {
  provider   = "prisma-client-js"
  engineType = "client"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}

enum ProviderType {
  PREHRAJTO
}

model Profile {
  @@map("profile")

  id   Int    @id @default(autoincrement())
  name String

  familyId Int
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model Family {
  @@map("family")

  id       Int    @id @default(autoincrement())
  email    String @unique
  password String

  profiles Profile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Movie {
  @@map("movie")

  id            Int          @id @default(autoincrement())
  title_en      String?
  title_cz      String?
  type          String
  origins       String[]
  isAdult       Boolean      @default(false)
  length        Int?
  year          Int?
  providerId    String?
  providerType  ProviderType
  description   String?
  genres        MovieGenre[]

  @@index([title_en])
  @@index([title_cz])
}

model Genre {
  @@map("genre")

  id     Int          @id @default(autoincrement())
  name   String       @unique
  movies MovieGenre[]
}

model MovieGenre {
  @@map("movie_genre")

  movieId  Int
  genreId  Int
  movie    Movie @relation(fields: [movieId], references: [id])
  genre    Genre @relation(fields: [genreId], references: [id])

  @@id([movieId, genreId])
  @@index([genreId])
}